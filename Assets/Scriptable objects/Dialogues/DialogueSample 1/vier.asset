  DialogueText: "\u0412 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u043C \u043C\u0438\u0440\u0435
    \u0442\u0430\u043A\u0442\u044B \u0438\u0434\u0443\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u043F\u0435\u0440\u0451\u0434 \u0438 \u043D\u0435\u0442 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u0432\u043E\u0437\u0440\u0430\u0442\u0438\u0442\u044C\u0441\u044F \u0432\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u043D\u043E \u0442\u0430\u043A \u043A\u0430\u043A
    \u043C\u044B \u0432 \u0432\u0438\u0434\u0435\u043E\u0438\u0433\u0440\u0435, \u0442\u043E
    \u0442\u0443\u0442 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u0432\u0441\u0451!
    \u0422\u0430\u043A \u0447\u0442\u043E \u043D\u0435 \u0431\u043E\u0439\u0441\u044F
    \u0434\u0435\u043B\u0430\u0442\u044C \u043E\u0448\u0438\u0431\u043E\u043A, \u0442\u044B
