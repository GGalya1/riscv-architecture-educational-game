  DialogueText: "\u0422\u044B \u043F\u043E\u043C\u043D\u0438\u0448\u044C \u043A\u0430\u043A\u0438\u0435
    \u0427\u0430\u0441\u0442\u0438 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    Sequentille, \u0430 \u043A\u0430\u043A\u0438\u0435 kombinatorische ?"
  emotionIndex: 5
  firstAnswer: "\u0425\u043C\u043C\u043C, \u044F \u0434\u0443\u043C\u0430\u044E \u043B\u0443\u0447\u0448\u0435
    \u0434\u0430\u0432\u0430\u0439 \u043F\u043E\u0432\u0442\u043E\u0440\u0438\u043C
